  "build": {
    "current": {
      "dsl"           : "groovy",
      "multiplatform" : false,
      "publishing"    : "github-packages",
      "versionCatalog": false,
      "ktlint"        : false
    },
    "desired": {
      "dsl"           : "kotlin",
      "multiplatform" : true,
      "publishing"    : "maven-central",
      "versionCatalog": true,
      "ktlint"        : true
    }
  },
  "libraries": [
